# Lightweight web-only image for the Azure App Service POC.
#
# This intentionally installs only the FastAPI/OpenAI/upload dependencies from
# backend/requirements.txt. The heavy FEM/CadQuery image stays in Dockerfile for
# later CAD-export work, but the public POC should start quickly.

FROM python:3.12-slim-bookworm

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PORT=8000 \
    PYTHONPATH=/app

WORKDIR /app

COPY backend/requirements.txt ./requirements.txt
RUN python -m pip install --upgrade pip \
    && pip install -r requirements.txt

COPY main.py startup.sh ./
COPY backend/ ./backend/

EXPOSE 8000

CMD ["bash", "startup.sh"]
